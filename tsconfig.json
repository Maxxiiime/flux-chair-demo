{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		"baseUrl": ".",
		"paths": {
			"@/components/*": ["src/components/*"],
			"@/assets/*": ["src/assets/*"],
			"@/features/*": ["src/features/*"],
			"@/hooks/*": ["src/hooks/*"],
			"@/lib/*": ["src/lib/*"],
			"@/router/*": ["src/router/*"],
			"@/pages/*": ["src/router/pages/*"],
			"@/helpers/*": ["src/helpers/*"],
			"@/stores/*": ["src/stores/*"],
			"@/data/*": ["src/data/*"],
			"@/theme/*": ["src/theme/*"],
			"@/layouts/*": ["src/layouts/*"],
			"@/types/*": ["src/types/*"],
			"@/root/*": ["./*"]
		},

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"allowJs": true,
		"checkJs": false
	},
	"include": ["src"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
